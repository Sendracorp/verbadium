# ── Supabase (auth + database) ────────────────────────────────────────────
# Create a project at https://supabase.com, then: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key — server only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Lemon Squeezy (payments, merchant of record) ──────────────────────────
# https://app.lemonsqueezy.com → Settings → API.
LEMONSQUEEZY_API_KEY=YOUR-API-KEY
LEMONSQUEEZY_STORE_ID=YOUR-STORE-ID
# Settings → Webhooks → signing secret for the /api/webhooks/lemonsqueezy endpoint.
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR-WEBHOOK-SECRET
# Variant ID of the product for each course (one env var per course slug).
LEMONSQUEEZY_VARIANT_CATALAN_A1=YOUR-VARIANT-ID

# ── Site ──────────────────────────────────────────────────────────────────
# Used for auth redirects and checkout return URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Local QA only — never set in production ───────────────────────────────
# COURSE_BYPASS_PAYWALL=true
